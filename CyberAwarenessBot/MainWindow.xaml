        </Border>

        <!-- ROW 2: CHAT MESSAGES AREA -->
        <Border Grid.Row="2" Background="#0D1117" Margin="15,10,15,0">
            <ScrollViewer x:Name="ChatScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="ChatPanel" Margin="5"/>
            </ScrollViewer>
        </Border>

        <!-- ROW 3: SENTIMENT / MOOD BAR -->
        <Border Grid.Row="3" Background="#161B22" Margin="15,8,15,0"
                CornerRadius="6" Padding="12,8"
                BorderBrush="#30363D" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="MOOD:"
                           Foreground="#8B949E" FontFamily="Consolas"
                           FontSize="11" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>

                <ProgressBar Grid.Column="1" x:Name="SentimentBar"
                             Height="8" Minimum="0" Maximum="100" Value="50"
                             Background="#30363D" Foreground="#00FF88"
                             BorderThickness="0"/>

                <TextBlock Grid.Column="2" x:Name="SentimentLabel"
                           Text="Neutral ūüėź" Foreground="#8B949E"
                           FontFamily="Consolas" FontSize="11"
                           VerticalAlignment="Center" Margin="10,0,0,0"/>
            </Grid>
        </Border>

        <!-- ROW 4: INPUT AREA -->
        <Border Grid.Row="4" Background="#161B22" Padding="15,12"
                BorderBrush="#30363D" BorderThickness="0,1,0,0" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         x:Name="UserInputBox"
                         Style="{StaticResource InputBoxStyle}"
                         KeyDown="UserInputBox_KeyDown"
                         VerticalAlignment="Center"
                         Height="42"
                         ToolTip="Type your message and press Enter or click Send"/>

                <Button Grid.Column="1"
                        Content="‚ě§  Send"
                        Style="{StaticResource SendButtonStyle}"
                        Click="SendButton_Click"
                        Height="42" Margin="10,0,0,0"/>

                <Button Grid.Column="2"
                        Content="ūüóĎ Clear"
                        Style="{StaticResource ClearButtonStyle}"
                        Click="ClearButton_Click"
                        Height="42" Margin="8,0,0,0"/>
            </Grid>
        </Border>

        <!-- ROW 5: STATUS BAR -->
        <Border Grid.Row="5" Background="#161B22" Padding="15,6"
                BorderBrush="#30363D" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="StatusLabel"
                           Text="ūüí¨ Ready ‚ÄĒ Type a message to begin..."
                           Foreground="#8B949E" FontFamily="Consolas" FontSize="11"/>
                <TextBlock Grid.Column="1" x:Name="MemoryLabel"
                           Text="ūüß† Memory: 0 items"
                           Foreground="#8B949E" FontFamily="Consolas" FontSize="11"/>
            </Grid>
        </Border>

    </Grid>
</Window>
